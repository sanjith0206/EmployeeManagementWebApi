                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateEmployeeDTO": {
        "required": [
          "firstName",
          "lastName",
          "email",
          "department",
          "salary",
          "hireDate"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string"
          },
          "lastName": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "department": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "salary": {
            "maximum": 1000000,
            "minimum": 1000,
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "hireDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateEmployeeDTO": {
        "required": [
          "firstName",
          "lastName",
          "email",
          "department",
          "salary",
          "hireDate"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string"
          },
          "lastName": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "department": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "salary": {
            "maximum": 1000000,
            "minimum": 1000,
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "hireDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "temperatureF": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Employee"
